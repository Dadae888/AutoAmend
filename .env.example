# Copy to .env for local development. In production (Render), set these as
# real environment variables in the service's dashboard instead of a file.

# console.mistral.ai -> API Keys
MISTRAL_API_KEY=your-mistral-api-key
MISTRAL_MODEL=mistral-medium-latest

# dashboard.stripe.com -> Developers -> API keys (use sk_test_... while testing)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
# dashboard.stripe.com -> Developers -> Webhooks -> your endpoint -> Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
# dashboard.stripe.com -> Product catalog -> "AutoAmend AI Pro" -> the recurring Price's id
STRIPE_PRICE_ID=price_your-recurring-price-id

# supabase.com -> Project Settings -> Database -> Connection string (URI, pooler
# port 6543) -> change "postgresql://" to "postgresql+psycopg://" and fill in
# your database password
DATABASE_URL=postgresql+psycopg://postgres.xxxx:your-password@aws-0-region.pooler.supabase.com:6543/postgres

# How many billable amendment generations a device gets before the paywall kicks in
FREE_QUOTA=3

# Comma-separated list of allowed origins for the Flutter web build, e.g.
# https://autoamend.netlify.app,http://localhost:8080 . Use * only for local dev.
CORS_ORIGINS=*

# Base URL this backend is reachable at (used to build Stripe success/cancel URLs)
PUBLIC_APP_URL=http://127.0.0.1:8000
